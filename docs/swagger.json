  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "contact": {
        "type": "object",
        "properties": {
          "_id": {
            "description": "Contact id",
            "type": "string",
            "example": "65ca67e7ae7f10c88b598384"
          },
          "userId": {
            "description": "The id of the user the contact belongs to",
            "type": "string",
            "example": "65ca67e7ae7f10c88b598384"
          },
          "name": {
            "description": "Contact name",
            "type": "string",
            "example": "Halyna"
          },
          "phoneNumber": {
            "description": "Contact phone number",
            "type": "string",
            "example": "+380991234567"
          },
          "email": {
            "description": "Contact email",
            "type": "string",
            "example": "halyna@example.com"
          },
          "photo": {
            "description": "Contact's avatar",
            "type": "string",
            "example": "https://res.cloudinary.com/dyuf9mnwr/image/upload/v1752609912/ixlpz2qfe2y3jpovcqad.png"
          },
          "isFavourite": {
            "description": "Is contact favourite",
            "type": "boolean",
            "example": false
          },
          "contactType": {
            "description": "Types of contact: work, home and personal",
            "type": "string",
            "enum": [
              "work",
              "home",
              "personal"
            ],
            "example": "personal"
          },
          "createdAt": {
            "description": "The time contact was created",
            "type": "string",
            "example": "2025-07-15T20:05:12.235Z"
          },
          "updatedAt": {
            "description": "The time contact was updated",
            "type": "string",
            "example": "2025-07-15T20:05:12.235Z"
          }
        }
      }
    },
    "responses": {
      "401": {
        "description": "Unauthorized error",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": [
                "status",
                "message",
                "data"
              ],
              "properties": {
                "status": {
                  "type": "integer",
                  "example": 401
                },
                "message": {
                  "type": "string",
                  "example": "UnauthorizedError"
                },
                "data": {
                  "type": "object",
                  "required": [
                    "message"
                  ],
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Please provide Authorization header"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "404": {
        "description": "Unauthorized error",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": [
                "status",
                "message",
                "data"
              ],
              "properties": {
                "status": {
                  "type": "integer",
                  "example": 404
                },
                "message": {
                  "type": "string",
                  "example": "NotFoundError"
                },
                "data": {
                  "type": "object",
                  "required": [
                    "message"
                  ],
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Contact not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
